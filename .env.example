# Copy to an env file (e.g. envs/nz.env) and fill in. One file per region.
# Bring the node up with:
#   docker compose -p pia-nz --env-file envs/nz.env up -d

# --- PIA account (required) ---
PIA_USER=p1234567
PIA_PASS=your_pia_password

# --- PIA region (required) ---
# Region ids: https://serverlist.piaservers.net/vpninfo/servers/v6
#   nz            = New Zealand
#   aus_melbourne = AU Melbourne
#   aus           = AU Sydney
PIA_LOC=nz

# --- Tailnet identity (required) ---
# The hostname this exit node shows up as in your Tailscale admin console.
TS_HOSTNAME=pia-nz-exit

# --- Tailscale auth (optional) ---
# Leave empty to authenticate once via the login URL printed to `docker logs`.
# Set a reusable, tagged auth key for hands-off redeploys.
TS_AUTHKEY=

# --- Optional ---
# Your LAN CIDR, allowed to bypass the VPN so the container stays reachable
# and can resolve local hosts. Leave empty to route everything through PIA.
LAN_NETWORK=192.168.1.0/24

# DNS servers used inside the tunnel.
VPN_DNS=8.8.8.8,8.8.4.4

# Tailscale networking mode. Default (false) = kernel forwarding: fastest, and
# what you want on any normal Linux Docker host. Set true to fall back to
# userspace networking if your host cannot grant NET_ADMIN/NET_RAW or a TUN
# device to the tailscale container (some NAS/rootless setups).
TS_USERSPACE=false
